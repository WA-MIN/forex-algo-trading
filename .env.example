# ── Market / annualisation ─────────────────────────────────────────────────────
# FX trades 24 h/day; change BARS_PER_TRADING_DAY to ~1440 for a correct
# FX annualisation factor instead of the US-equity default of 390.
TRADING_DAYS_PER_YEAR=252
BARS_PER_TRADING_DAY=390

# ── Capital ────────────────────────────────────────────────────────────────────
DEFAULT_CAPITAL=10000.0

# ── Data pipeline ──────────────────────────────────────────────────────────────
# Minimum 1-min bars required for a calendar day to be kept after cleaning.
# 1200 ≈ 83 % of a full 1440-bar FX day.
MIN_BARS_PER_DAY=1200

# Rows purged from the tail of every training window.
# Must always be >= HORIZON_SECONDARY to prevent label leakage.
PURGE_ROWS=15

# Forward-return horizons used when building labels.
HORIZON_PRIMARY=5
HORIZON_SECONDARY=15

# ── Features ───────────────────────────────────────────────────────────────────
# Rolling window (bars) for the realised-vol regime feature.
VOL_REGIME_WINDOW=30

# Expanding-window quantile threshold above which a bar is "high volatility".
VOL_HIGH_REGIME_PERCENTILE=0.80

# ── Engine ─────────────────────────────────────────────────────────────────────
# Rolling window (bars) for the rolling Sharpe display in the HTML report.
ROLLING_SHARPE_WINDOW=390

# ── Walk-forward ───────────────────────────────────────────────────────────────
DEFAULT_N_FOLDS=5
